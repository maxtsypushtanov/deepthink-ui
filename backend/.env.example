# DeepThink UI — Backend Configuration

# Database
DATABASE_URL=sqlite+aiosqlite:///./deepthink.db

# Provider API Keys (add the ones you need)
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
CLOUDRU_API_KEY=

# Optional: custom OpenAI-compatible endpoint
CUSTOM_API_KEY=
CUSTOM_BASE_URL=

# Multi-agent pipeline
GITHUB_PERSONAL_ACCESS_TOKEN=
GITHUB_MCP_SERVER=stdio
SANDBOX_PROVIDER=e2b
E2B_API_KEY=
ARCHITECT_MODEL=openai/gpt-oss-120b
DEVELOPER_MODEL=zai-org/GLM-4.7
TESTER_MODEL=zai-org/GLM-4.7-Flash
ORCHESTRATOR_MODEL=zai-org/GLM-4.6
MAX_ITERATIONS=5
STOP_ON_CLEAN_ITERATIONS=2

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:5173"]
